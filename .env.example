# ========================
# Server
# ========================
# WSL2 コンテナ内で動かすため 0.0.0.0 バインドが必須
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# 同時生成は 1 に固定（16GB VRAM）
GPU_CONCURRENCY=1

# ========================
# Storage
# ========================
# HuggingFace モデルキャッシュ（data/models）
HF_HOME=./data/models
# 生成画像の保存先
IMAGES_DIR=./data/images

# ========================
# Models
# ========================
# Gemma 4 E4B（bitsandbytes 4bit で常駐）
LLM_MODEL_ID=google/gemma-4-E4B-it

# --- 差し替え例 ---
# Heretic v1.2.0 ARA で拒否のみ除去（KL 0.0058）。センシティブなプロンプトを通したい場合に。
# LLM_MODEL_ID=coder3101/gemma-4-E4B-it-heretic

# Anima（呼出時ロード、bfloat16）
IMAGE_MODEL_ID=hdae/diffusers-anima-preview

# --- 差し替え例 ---
# .safetensors / .ckpt で終わるパスは AnimaPipeline.from_single_file() で読み込む。
# Civitai などのマージ版 Anima を試す場合の入口。モデルによってはレイアウト違いで弾かれる。
# IMAGE_MODEL_ID=./waiANIMA_v10.safetensors

# ========================
# Generation defaults
# ========================
DEFAULT_WIDTH=896
DEFAULT_HEIGHT=1152
DEFAULT_STEPS=32
DEFAULT_CFG=4.0
