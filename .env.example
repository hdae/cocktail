# ========================
# Server
# ========================
# WSL2 コンテナ内で動かすため 0.0.0.0 バインドが必須
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# 同時生成は 1 に固定（16GB VRAM）
GPU_CONCURRENCY=1

# ========================
# Storage
# ========================
# HuggingFace モデルキャッシュ
HF_HOME=./data/models
# Civitai 等の単体ウェイト配置先
WEIGHTS_DIR=./data/weights
# 生成画像の保存先
IMAGES_DIR=./data/images

# ========================
# Models — LLM
# ========================
# Gemma 4 E4B（bitsandbytes 4bit で常駐）
LLM_MODEL_ID=google/gemma-4-E4B-it

# --- 差し替え例 ---
# Heretic v1.2.0 ARA で拒否のみ除去（KL 0.0058）。センシティブなプロンプトを通したい場合に。
# LLM_MODEL_ID=coder3101/gemma-4-E4B-it-heretic

# ========================
# Models — Image
# ========================
# IMAGE_MODEL_ID には次のいずれかを指定できる:
#   - Civitai の AIR(URN)   例: urn:air:anima:checkpoint:civitai:<modelId>@<versionId>
#                           → ${WEIGHTS_DIR}/civitai/{slug}-{sha256[:12]}.{ext} に自動配置
#   - HuggingFace リポ ID   例: hdae/diffusers-anima-preview
#   - 明示ローカルパス       例: ./data/weights/civitai/waianima-v10-<sha12>.safetensors
# デフォルトは wai-anima v10 の AIR。
IMAGE_MODEL_ID=urn:air:anima:checkpoint:civitai:2544636@2859702

# Civitai の gated モデルを使うときのみ設定。
# CIVITAI_TOKEN=

# ========================
# VRAM 運用モード
# ========================
# auto       : 起動時に VRAM を見て coresident / swap を自動選択（既定）
# swap       : ターンごとに LLM ↔ Image を入れ替え（16GB 以下向け）
# coresident : 両モデルを GPU 常駐（24GB+ 向け）
RESIDENCY_MODE=auto
# coresident に切り替える VRAM 下限（GiB）
RESIDENCY_CORESIDENT_THRESHOLD_GB=20.0

# 起動時に fetch_models + モデルプリロードを実行する。
# テストから lifespan を乗っ取るときだけ false。
STARTUP_PRELOAD=true

# ========================
# Generation defaults
# ========================
DEFAULT_WIDTH=896
DEFAULT_HEIGHT=1152
DEFAULT_STEPS=32
DEFAULT_CFG=4.0
